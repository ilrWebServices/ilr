{#
/**
 * @file
 * Theme override to display a tabs paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 * - content: All paragraph items.
 * - attributes: HTML attributes for the containing element.
 *
 * @see template_preprocess_paragraph()
 * @see union_marketing_preprocess_paragraph__tabs()
 *
 * @ingroup themeable
 */
#}
{% include '@union/_tout.twig' with {
  heading: paragraph.field_heading.value,
  content: content.field_body,
  media: content.field_media,
  button_url: content.field_link[0]['#url'],
  button_text: content.field_link[0]['#title'],
  attributes: attributes.addClass([
    'cu-component',
    'cu-component--' ~ paragraph.bundle|clean_class
  ])
} only %}
